model Bank {
    id        String   @id @default(uuid())
    name      String
    color     String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    logoId String @unique
    logo   Image  @relation("BankLogo", fields: [logoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

    @@map("banks")
}
