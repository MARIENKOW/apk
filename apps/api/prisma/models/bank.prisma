model Bank {
    id        String   @id @default(uuid())
    name       String
    color      String
    nameColor  String   @default("#ffffff")
    logoHeight Int      @default(30)
    // Произвольная ссылка. Строгой валидации нет — хранится как есть.
    link       String   @default("")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    logoId String @unique
    logo   Image  @relation("BankLogo", fields: [logoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

    @@map("banks")
}
